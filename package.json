{
  "name": "cmux-web",
  "version": "0.1.0",
  "description": "A web-based terminal multiplexer — cmux for the browser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jinbe/cmux-web.git"
  },
  "keywords": [
    "terminal",
    "multiplexer",
    "tmux",
    "cmux",
    "web-terminal",
    "pty",
    "ghostty"
  ],
  "type": "module",
  "bin": {
    "cmux-web": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun --watch src/server/index.ts",
    "start": "bun dist/server/index.js",
    "cli": "bun src/cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bun-pty": "^0.4.8",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "ghostty-web": "^0.4.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/express": "^4.17.21",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0"
  }
}
